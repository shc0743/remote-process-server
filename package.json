{
  "name": "remote-process-server",
  "version": "3.1.0-beta.1",
  "description": "A client/server system for remotely creating and managing processes",
  "bin": {
    "remote-process-server": "dist/entry.min.js"
  },
  "keywords": [
    "backend",
    "server",
    "process"
  ],
  "homepage": "https://github.com/shc0743/remote-process-server#readme",
  "bugs": {
    "url": "https://github.com/shc0743/remote-process-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shc0743/remote-process-server.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "files": [
    "README.md",
    "LICENSE",
    ".gitignore",
    ".github/**/*",
    ".scripts/**/*",
    "postinstall.js",
    "entry.js",
    "maintainance.js",
    "dist/**/*",
    "test.js",
    "client.py",
    "client/*.py",
    "server.cpp",
    "server_version.h",
    "server/**/*",
    "compile.*",
    "sys_name.py",
    "native/**/*",
    "rmpsm_server.*"
  ],
  "scripts": {
    "postinstall": "node postinstall.js",
    "test": "node test.js",
    "build": "npm run build:entry && npm run build:maintainance",
    "build:entry": "rolldown entry.js --minify -f es --platform node --file dist/entry.min.js -e ./maintainance.js",
    "build:maintainance": "rolldown maintainance.js --minify -f es --platform node --file dist/maintainance.js -e ./native/delayed_delete.windows_amd64.node"
  },
  "devDependencies": {
    "koffi": "^2.16.0",
    "rolldown": "^1.0.0-rc.16"
  }
}
